# === Database ===
DATABASE_URL="postgresql://finfo:password@localhost:5432/finfo"
REDIS_URL="redis://localhost:6379"

# === API Keys (모두 무료 발급) ===
# FRED (https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# BLS (https://www.bls.gov/developers/)
BLS_API_KEY=your_bls_api_key_here

# BEA (https://apps.bea.gov/API/signup/)
BEA_API_KEY=your_bea_api_key_here

# 한국은행 ECOS (https://ecos.bok.or.kr/api/)
ECOS_API_KEY=your_ecos_api_key_here

# 통계청 KOSIS (https://kosis.kr/openapi/)
KOSIS_API_KEY=your_kosis_api_key_here

# 공공데이터포털 (https://www.data.go.kr/)
PUBLIC_DATA_API_KEY=your_public_data_api_key_here

# SEC EDGAR (이메일 포함 필수)
SEC_EDGAR_USER_AGENT="finfo-service your@email.com"

# === App ===
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
